# Copy to .env next to docker-compose.yml and adjust.
# Start Cockroach + API + web: docker compose --env-file .env up --build

SESSION_SECRET=replace-with-at-least-32-random-characters

# Browser origin for the nginx front door (SPA + proxied /api)
CORS_ORIGIN=http://localhost:8080
PUBLIC_WEB_ORIGIN=http://localhost:8080

# OIDC: register this redirect URI in your IdP when using Compose in front of nginx:
# OIDC_REDIRECT_URI=http://localhost:8080/callback
# OIDC_ISSUER=...
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...

# API DATABASE_URL is set inside docker-compose.yml for the api service (CockroachDB service name: cockroach).
