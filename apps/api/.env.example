# Copy to .env and fill values. OIDC_* are required for real login (see IdP console registration).
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
PUBLIC_WEB_ORIGIN=http://localhost:5173

# CockroachDB (PostgreSQL wire protocol). Local single-node example:
DATABASE_URL=postgresql://root@127.0.0.1:26257/defaultdb?sslmode=disable

SESSION_SECRET=replace-with-at-least-32-random-characters

# Register a confidential client in your IdP with redirect URI matching the SPA:
# OIDC_REDIRECT_URI=http://localhost:5173/callback
OIDC_ISSUER=https://your-tenant.example.com/realms/your-realm
OIDC_CLIENT_ID=portal-spa
OIDC_CLIENT_SECRET=your-confidential-secret
OIDC_REDIRECT_URI=http://localhost:5173/callback

OIDC_MFA_AMR_VALUES=mfa otp pwd
# OIDC_MFA_ACR_HINT=mfa

OIDC_RECOVERY_PATH=/login-actions/reset-credentials
